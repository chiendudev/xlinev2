"""
Test module for Redis Event Bus implementation.
Comprehensive tests with mocking for Redis operations.
"""

import json
from datetime import datetime
from unittest.mock import AsyncMock, patch
from uuid import uuid4

import pytest
import redis.asyncio as redis

from xline.core.events.bus import Event, EventSubscriptionError, PublishResult, SubscriptionId
from xline.core.reliability.circuit_breaker import CircuitBreakerError
from xline.infrastructure.messaging.redis.bus import (
    RedisConnectionError,
    RedisEventBus,
    RedisSerializationError,
)


class TestRedisEventBus:
    """Test Redis Event Bus implementation."""

    @pytest.fixture
    def red        # Mock DLQ behavior - return True to trigger DLQ move
        with patch.object(event_bus, "_should_move_to_dlq", return_value=True), \
             patch.object(event_bus, "_move_to_dlq") as mock_move_dlq, \
             patch("redis.asyncio.from_url", return_value=mock_redis):rl(self) -> str:
        """Redis URL for testing."""
        return "redis://localhost:6379/0"

    @pytest.fixture
    def event_bus(self, redis_url: str) -> RedisEventBus:
        """Create Redis Event Bus instance."""
        return RedisEventBus(
            redis_url=redis_url,
            max_retries=2,
            retry_delay=0.1,  # Fast retries for testing
            consumer_group="test-group",
        )

    @pytest.fixture
    def sample_event(self) -> Event:
        """Create sample event for testing."""
        return Event(
            id=str(uuid4()),
            type="test.event",
            source="test_service",
            timestamp=datetime.now(),
            data={"test_key": "test_value", "number": 42},
        )

    @pytest.fixture
    def mock_redis(self) -> AsyncMock:
        """Create mock Redis client."""
        mock = AsyncMock(spec=redis.Redis)
        mock.ping = AsyncMock(return_value=True)
        mock.xadd = AsyncMock(return_value=b"1234567890-0")
        mock.xgroup_create = AsyncMock(return_value=True)
        mock.xreadgroup = AsyncMock(return_value=[])
        mock.xack = AsyncMock(return_value=1)
        mock.close = AsyncMock()
        return mock

    async def test_initialization_success(self, event_bus: RedisEventBus, mock_redis: AsyncMock):
        """Test successful initialization."""
        with patch("redis.asyncio.from_url", return_value=mock_redis):
            result = await event_bus.initialize()
            assert result is True
            assert event_bus._initialized is True
            mock_redis.ping.assert_called_once()

    async def test_initialization_failure(self, event_bus: RedisEventBus):
        """Test initialization failure."""
        with patch("redis.asyncio.from_url", side_effect=redis.RedisError("Connection failed")):
            result = await event_bus.initialize()
            assert result is False
            assert event_bus._initialized is False

    async def test_health_check_healthy(self, event_bus: RedisEventBus, mock_redis: AsyncMock):
        """Test health check when Redis is healthy."""
        with patch("redis.asyncio.from_url", return_value=mock_redis):
            await event_bus.initialize()
            health = await event_bus.health_check()
            assert health is True

    async def test_health_check_unhealthy(self, event_bus: RedisEventBus, mock_redis: AsyncMock):
        """Test health check when Redis is unhealthy."""
        mock_redis.ping.side_effect = redis.RedisError("Connection lost")
        with patch("redis.asyncio.from_url", return_value=mock_redis):
            await event_bus.initialize()
            health = await event_bus.health_check()
            assert health is False

    async def test_health_check_not_initialized(self, event_bus: RedisEventBus):
        """Test health check when not initialized."""
        health = await event_bus.health_check()
        assert health is False

    async def test_publish_success(
        self, event_bus: RedisEventBus, mock_redis: AsyncMock, sample_event: Event
    ):
        """Test successful event publishing."""
        expected_message_id = b"1234567890-0"
        mock_redis.xadd.return_value = expected_message_id

        with patch("redis.asyncio.from_url", return_value=mock_redis):
            await event_bus.initialize()
            result = await event_bus.publish(sample_event)

            assert isinstance(result, PublishResult)
            assert result.success is True
            assert result.event_id == sample_event.id
            assert result.message_id == str(expected_message_id)

            # Verify Redis call
            mock_redis.xadd.assert_called_once()
            call_args = mock_redis.xadd.call_args
            stream_name = call_args[0][0]
            event_data = call_args[0][1]

            assert stream_name == f"events:{sample_event.type}"
            assert event_data["id"] == sample_event.id
            assert event_data["type"] == sample_event.type

    async def test_publish_not_initialized(self, event_bus: RedisEventBus, sample_event: Event):
        """Test publishing when not initialized."""
        result = await event_bus.publish(sample_event)
        assert result.success is False
        assert "not initialized" in result.error

    async def test_publish_redis_error(
        self, event_bus: RedisEventBus, mock_redis: AsyncMock, sample_event: Event
    ):
        """Test publishing with Redis error."""
        mock_redis.xadd.side_effect = redis.RedisError("Stream error")

        with patch("redis.asyncio.from_url", return_value=mock_redis):
            await event_bus.initialize()
            result = await event_bus.publish(sample_event)

            assert result.success is False
            assert "Stream error" in result.error

    async def test_subscribe_success(self, event_bus: RedisEventBus, mock_redis: AsyncMock):
        """Test successful subscription."""
        mock_redis.xgroup_create.return_value = True

        async def test_handler(event: Event) -> None:
            pass

        with patch("redis.asyncio.from_url", return_value=mock_redis):
            with patch.object(event_bus, "_consume_events") as mock_consume:
                # Mock the consumer task to avoid infinite loop
                mock_consume.return_value = None

                await event_bus.initialize()
                subscription_id = await event_bus.subscribe("test.event", test_handler)

                assert isinstance(subscription_id, SubscriptionId)
                assert subscription_id.id is not None

                # Verify consumer group creation
                mock_redis.xgroup_create.assert_called_once_with(
                    "events:test.event", event_bus.consumer_group, id="0", mkstream=True
                )

    async def test_subscribe_not_initialized(self, event_bus: RedisEventBus):
        """Test subscription when not initialized."""

        async def test_handler(event: Event) -> None:
            pass

        with pytest.raises(EventSubscriptionError, match="not initialized"):
            await event_bus.subscribe("test.event", test_handler)

