            mock_redis.ping.assert_called_once()

    async def test_connect_with_retry_failure(self, event_bus: RedisEventBus):
        """Test connection failure after retries."""
        with patch("redis.asyncio.from_url", side_effect=redis.RedisError("Connection failed")):
