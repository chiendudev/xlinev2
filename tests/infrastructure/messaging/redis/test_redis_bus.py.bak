    async def test_circuit_breaker_integration(
        self, event_bus: RedisEventBus, mock_redis: AsyncMock, sample_event: Event
    ):
        """Test circuit breaker integration."""
        # Simulate circuit breaker being open
        event_bus.circuit_breaker._state = event_bus.circuit_breaker._state.OPEN

        with patch("redis.asyncio.from_url", return_value=mock_redis):
            await event_bus.initialize()

            # Health check should fail when circuit breaker is open
            with patch.object(
                event_bus.circuit_breaker, "call", side_effect=CircuitBreakerError("Circuit open")
            ):
                health = await event_bus.health_check()
                assert health is False

    @pytest.mark.asyncio
    async def test_consumer_event_processing(
        self, event_bus: RedisEventBus, mock_redis: AsyncMock, sample_event: Event
    ):
        """Test event consumer processing logic components."""
        processed_events = []

        async def test_handler(event: Event) -> None:
            processed_events.append(event)

        with patch("redis.asyncio.from_url", return_value=mock_redis):
            await event_bus.initialize()

            # Test event serialization and deserialization
            serialized_event = event_bus._serialize_event(sample_event)
            assert "id" in serialized_event
            assert "type" in serialized_event

            deserialized_event = event_bus._deserialize_event(serialized_event)
            assert deserialized_event.id == sample_event.id
            assert deserialized_event.type == sample_event.type

            # Test handler execution directly
            await test_handler(deserialized_event)

            # Verify processing
            assert len(processed_events) == 1
            assert processed_events[0].id == sample_event.id
            assert processed_events[0].type == sample_event.type

    @pytest.mark.asyncio
    async def test_dlq_functionality(
        self, event_bus: RedisEventBus, mock_redis: AsyncMock, sample_event: Event
    ):
        """Test Dead Letter Queue functionality."""
        with patch("redis.asyncio.from_url", return_value=mock_redis):
            await event_bus.initialize()

            # Test move to DLQ
            await event_bus._move_to_dlq(sample_event, "Test error")

            # Verify DLQ stream was called
            expected_stream = f"dlq:{sample_event.type}"
            mock_redis.xadd.assert_called()
            args, kwargs = mock_redis.xadd.call_args
            assert args[0] == expected_stream
            assert "dlq_error" in args[1]
            assert args[1]["dlq_error"] == "Test error"

