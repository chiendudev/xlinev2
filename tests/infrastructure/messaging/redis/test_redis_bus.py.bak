    async def test_unsubscribe(self, event_bus: RedisEventBus):
        """Test unsubscription."""
        subscription_id = SubscriptionId(id="test-subscription")
        result = await event_bus.unsubscribe(subscription_id)
        assert result is True

    async def test_cleanup(self, event_bus: RedisEventBus, mock_redis: AsyncMock):
        """Test cleanup functionality."""
        import asyncio

        with patch("redis.asyncio.from_url", return_value=mock_redis):
            # Create a real task that we can cancel
            async def dummy_consumer():
                try:
                    await asyncio.sleep(10)  # Long sleep, will be cancelled
                except asyncio.CancelledError:
                    pass

            # Create actual task for cleanup testing
            task = asyncio.create_task(dummy_consumer())
            event_bus._running_consumers["test"] = task

            await event_bus.initialize()
            await event_bus.cleanup()

            assert event_bus._initialized is False
            assert event_bus._redis is None
            assert len(event_bus._running_consumers) == 0
            mock_redis.close.assert_called_once()
            assert task.cancelled() or task.done()

    async def test_serialize_event(self, event_bus: RedisEventBus, sample_event: Event):
        """Test event serialization."""
        serialized = event_bus._serialize_event(sample_event)

        assert isinstance(serialized, dict)
        assert serialized["id"] == sample_event.id
        assert serialized["type"] == sample_event.type
        assert serialized["source"] == sample_event.source
        assert serialized["timestamp"] == sample_event.timestamp.isoformat()
        assert json.loads(serialized["data"]) == sample_event.data
        assert serialized["version"] == sample_event.version

    async def test_serialize_event_error(self, event_bus: RedisEventBus):
        """Test event serialization error."""
        # Create event with non-serializable data
        bad_event = Event(
            id="test",
            type="test.event",
            source="test",
            timestamp=datetime.now(),
            data={"bad": object()},  # Non-serializable object
        )

        with pytest.raises(RedisSerializationError):
            event_bus._serialize_event(bad_event)

    async def test_deserialize_event(self, event_bus: RedisEventBus, sample_event: Event):
        """Test event deserialization."""
        # First serialize the event
        serialized = event_bus._serialize_event(sample_event)

        # Convert to bytes format as Redis would return
        message_data = {k.encode(): v.encode() for k, v in serialized.items()}

        # Deserialize
        deserialized = event_bus._deserialize_event(message_data)

        assert deserialized.id == sample_event.id
        assert deserialized.type == sample_event.type
        assert deserialized.source == sample_event.source
        assert deserialized.data == sample_event.data
        assert deserialized.version == sample_event.version

    async def test_deserialize_event_error(self, event_bus: RedisEventBus):
        """Test event deserialization error."""
        # Invalid message data
        bad_data = {b"invalid": b"data"}

        with pytest.raises(RedisSerializationError):
            event_bus._deserialize_event(bad_data)

    async def test_connect_with_retry_success(
        self, event_bus: RedisEventBus, mock_redis: AsyncMock
