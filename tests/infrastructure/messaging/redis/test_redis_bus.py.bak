    @pytest.mark.asyncio
    async def test_should_move_to_dlq_no_redis(self, event_bus: RedisEventBus):
        """Test should_move_to_dlq when Redis not connected."""
        result = await event_bus._should_move_to_dlq("test-id", "test.event")
        assert result is False

    @pytest.mark.asyncio
    async def test_should_move_to_dlq_with_pending_messages(
        self, event_bus: RedisEventBus, mock_redis: AsyncMock
    ):
        """Test should_move_to_dlq with pending messages."""
        import asyncio

        with patch("redis.asyncio.from_url", return_value=mock_redis):
            await event_bus.initialize()

            # Create async coroutines for the mock returns
            async def high_delivery_count():
                return [{"times_delivered": 5}]

            async def low_delivery_count():
                return [{"times_delivered": 1}]

            # Mock pending message with high delivery count
            mock_redis.xpending_range.return_value = high_delivery_count()

            result = await event_bus._should_move_to_dlq("test-id", "test.event")
            assert result is True

            # Mock pending message with low delivery count
            mock_redis.xpending_range.return_value = low_delivery_count()

            result = await event_bus._should_move_to_dlq("test-id", "test.event")
            assert result is False

    @pytest.mark.asyncio
    async def test_should_move_to_dlq_exception(
        self, event_bus: RedisEventBus, mock_redis: AsyncMock
