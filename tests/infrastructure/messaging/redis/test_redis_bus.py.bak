    @pytest.mark.asyncio
    async def test_consumer_loop_with_messages(
        self, event_bus: RedisEventBus, mock_redis: AsyncMock, sample_event: Event
    ):
        """Test consumer loop processing messages."""
        import asyncio
        
        processed_events = []

        async def test_handler(event: Event) -> None:
            processed_events.append(event)

        # Setup message data
        serialized_event = event_bus._serialize_event(sample_event)
        message_data = {k.encode(): v.encode() for k, v in serialized_event.items()}

        # Mock Redis responses: first call has message, second call raises CancelledError
        async def mock_xreadgroup(*args, **kwargs):
            if not hasattr(mock_xreadgroup, 'called'):
                mock_xreadgroup.called = True
                return [(b"events:test.event", [(b"1234567890-0", message_data)])]
            else:
                raise asyncio.CancelledError()

        mock_redis.xreadgroup.side_effect = mock_xreadgroup

        with patch("redis.asyncio.from_url", return_value=mock_redis):
            await event_bus.initialize()
            event_bus._subscriptions["test.event"] = [test_handler]

            # Run consumer loop briefly
            try:
                await event_bus._consume_events("test.event", "events:test.event")
            except asyncio.CancelledError:
                pass

            # Verify message was processed
            assert len(processed_events) == 1
            assert processed_events[0].id == sample_event.id
            mock_redis.xack.assert_called()

    @pytest.mark.asyncio
    async def test_consumer_loop_dlq_error_recovery(
        self, event_bus: RedisEventBus, mock_redis: AsyncMock, sample_event: Event
    ):
        """Test consumer loop DLQ error handling and recovery."""
        import asyncio

        # Setup message data
        serialized_event = event_bus._serialize_event(sample_event)
        message_data = {k.encode(): v.encode() for k, v in serialized_event.items()}

        # Mock Redis responses
        async def mock_xreadgroup(*args, **kwargs):
            if not hasattr(mock_xreadgroup, 'called'):
                mock_xreadgroup.called = True
                return [(b"events:test.event", [(b"1234567890-0", message_data)])]
            else:
                raise asyncio.CancelledError()

        mock_redis.xreadgroup.side_effect = mock_xreadgroup

        # Mock should_move_to_dlq to return True
        async def mock_should_move_to_dlq(*args):
            return True

        # Mock _move_to_dlq to raise exception
        async def mock_move_to_dlq_error(*args):
            raise Exception("DLQ move failed")

        with patch("redis.asyncio.from_url", return_value=mock_redis):
            await event_bus.initialize()

            with patch.object(event_bus, '_should_move_to_dlq', side_effect=mock_should_move_to_dlq):
                with patch.object(event_bus, '_move_to_dlq', side_effect=mock_move_to_dlq_error):
                    # Run consumer loop briefly
                    try:
                        await event_bus._consume_events("test.event", "events:test.event")
                    except asyncio.CancelledError:
                        pass

                    # Should handle DLQ error gracefully

    @pytest.mark.asyncio
    async def test_consumer_loop_uninitialized_stop(
        self, event_bus: RedisEventBus, mock_redis: AsyncMock
    ):
        """Test consumer loop stops when event bus is uninitialized."""
        import asyncio

        with patch("redis.asyncio.from_url", return_value=mock_redis):
            await event_bus.initialize()

            # Set initialized to False to trigger loop exit
            async def mock_xreadgroup(*args, **kwargs):
                if not hasattr(mock_xreadgroup, 'called'):
                    mock_xreadgroup.called = True
                    event_bus._initialized = False  # Trigger loop exit
                    return []
                else:
                    raise asyncio.CancelledError()

            mock_redis.xreadgroup.side_effect = mock_xreadgroup

            # Run consumer loop
            await event_bus._consume_events("test.event", "events:test.event")

            # Loop should exit gracefully when _initialized becomes False

    @pytest.mark.asyncio
    async def test_consumer_loop_sleep_on_error(
        self, event_bus: RedisEventBus, mock_redis: AsyncMock
    ):
        """Test consumer loop sleeps on error to prevent tight loop."""
        import asyncio

        call_count = 0
        
        async def mock_xreadgroup(*args, **kwargs):
            nonlocal call_count
            call_count += 1
            if call_count == 1:
                raise Exception("Redis error")
            else:
                raise asyncio.CancelledError()

        mock_redis.xreadgroup.side_effect = mock_xreadgroup

        with patch("redis.asyncio.from_url", return_value=mock_redis):
            await event_bus.initialize()

            # Mock asyncio.sleep to verify it's called
            with patch("asyncio.sleep", return_value=None) as mock_sleep:
                try:
                    await event_bus._consume_events("test.event", "events:test.event")
                except asyncio.CancelledError:
                    pass

                # Verify sleep was called after error
                mock_sleep.assert_called_once_with(1)


class TestRedisEventBusErrors:
    """Test error scenarios for Redis Event Bus."""

    @pytest.mark.asyncio
    async def test_handler_error_dlq_move_scenario(
        self, event_bus: RedisEventBus, mock_redis: AsyncMock
    ):
        """Test handler error with DLQ move scenario."""
        import json
        from datetime import datetime
        from xline.core.events.event import Event

        # Create test event
        class TestHandlerEvent(Event):
            data: str

        event = TestHandlerEvent(id="test-handler-error", data="test")
        message_id = b"1234567890-0"
        
        # Serialize event data
        fields = {
            b"id": event.id.encode(),
            b"event_type": "TestHandlerEvent",
            b"data": json.dumps({"data": event.data}).encode(),
            b"timestamp": datetime.now().isoformat().encode(),
        }

        # Create failing handler
        handler_calls = []
        
        async def failing_handler(e):
            handler_calls.append(e)
            raise ValueError("Handler processing failed")
        
        # Setup event bus
        event_bus._subscriptions["TestHandlerEvent"] = [failing_handler]

        call_count = 0
        
        async def mock_xreadgroup(*args, **kwargs):
            nonlocal call_count
            call_count += 1
            if call_count == 1:
                return [(b"events:TestHandlerEvent", [(message_id, fields)])]
            else:
                raise asyncio.CancelledError()

        mock_redis.xreadgroup.side_effect = mock_xreadgroup
        mock_redis.xack = AsyncMock()

        # Mock DLQ behavior - return True to trigger DLQ move
        with patch.object(event_bus, "_should_move_to_dlq", return_value=True), 
             patch.object(event_bus, "_move_to_dlq") as mock_move_dlq, 
             patch("redis.asyncio.from_url", return_value=mock_redis):
            
            await event_bus.initialize()
            
            try:
                await event_bus._consume_events("TestHandlerEvent", "events:TestHandlerEvent")
            except asyncio.CancelledError:
                pass

            # Verify handler was called and failed
            assert len(handler_calls) == 1
            assert handler_calls[0].data == "test"
            
            # Verify DLQ move was called
            mock_move_dlq.assert_called_once()
            
            # Verify message was acknowledged after DLQ move
            mock_redis.xack.assert_called_once_with(
                "events:TestHandlerEvent", event_bus.consumer_group, message_id
            )

    @pytest.mark.asyncio
    async def test_dlq_serialization_error_scenario(
        self, event_bus: RedisEventBus, mock_redis: AsyncMock
    ):
        """Test DLQ move with serialization error scenario."""
        message_id = b"1234567890-0"
        
        # Invalid fields that will cause deserialization to fail
        invalid_fields = {
            b"invalid": b"data",
            b"bad_format": b"test"
        }

        call_count = 0
        
        async def mock_xreadgroup(*args, **kwargs):
            nonlocal call_count
            call_count += 1
            if call_count == 1:
                return [(b"events:test.event", [(message_id, invalid_fields)])]
            else:
                raise asyncio.CancelledError()

        mock_redis.xreadgroup.side_effect = mock_xreadgroup
        mock_redis.xack = AsyncMock()

        # Mock DLQ behavior
        with patch.object(event_bus, "_should_move_to_dlq", return_value=True), 
             patch.object(event_bus, "_move_to_dlq") as mock_move_dlq, 
             patch("redis.asyncio.from_url", return_value=mock_redis):
            
            await event_bus.initialize()
            
            try:
                await event_bus._consume_events("test.event", "events:test.event")
            except asyncio.CancelledError:
                pass

            # Verify DLQ move was NOT called due to serialization failure
            mock_move_dlq.assert_not_called()
            
            # Verify message was NOT acknowledged due to DLQ failure
            mock_redis.xack.assert_not_called()

    @pytest.mark.asyncio
    async def test_processing_error_with_successful_dlq_recovery(
        self, event_bus: RedisEventBus, mock_redis: AsyncMock
    ):
        """Test processing error with successful DLQ recovery."""
        import json
        from datetime import datetime
        from xline.core.events.event import Event

        # Create test event
        class TestProcessingEvent(Event):
            data: str

        event = TestProcessingEvent(id="test-processing-error", data="test")
        message_id = b"1234567890-0"
        
        # Create fields that will cause processing error but can be serialized for DLQ
        fields = {
            b"id": event.id.encode(),
            b"event_type": "TestProcessingEvent", 
            b"data": json.dumps({"data": event.data}).encode(),
            b"timestamp": datetime.now().isoformat().encode(),
        }

        call_count = 0
        
        async def mock_xreadgroup(*args, **kwargs):
            nonlocal call_count
            call_count += 1
            if call_count == 1:
                return [(b"events:TestProcessingEvent", [(message_id, fields)])]
            else:
                raise asyncio.CancelledError()

        mock_redis.xreadgroup.side_effect = mock_xreadgroup
        mock_redis.xack = AsyncMock()

        # Force processing error by not having any subscriptions
        event_bus._subscriptions = {}

        # Mock DLQ behavior to simulate successful DLQ operation
        with patch.object(event_bus, "_should_move_to_dlq", return_value=True), 
             patch.object(event_bus, "_move_to_dlq") as mock_move_dlq, 
             patch("redis.asyncio.from_url", return_value=mock_redis):
            
            await event_bus.initialize()
            
            try:
                await event_bus._consume_events("TestProcessingEvent", "events:TestProcessingEvent") 
            except asyncio.CancelledError:
                pass

            # Verify DLQ move was called for processing error
            mock_move_dlq.assert_called_once()
            
            # Verify message was acknowledged after successful DLQ move
            mock_redis.xack.assert_called_once_with(
                "events:TestProcessingEvent", event_bus.consumer_group, message_id
            )

    def test_redis_connection_error(self):
        """Test RedisConnectionError."""
        error = RedisConnectionError("Connection failed")
        assert str(error) == "Connection failed"
        assert isinstance(error, Exception)

    def test_redis_serialization_error(self):
        """Test RedisSerializationError."""
        error = RedisSerializationError("Serialization failed")
        assert str(error) == "Serialization failed"
        assert isinstance(error, Exception)
